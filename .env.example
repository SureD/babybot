BABYBOT_HOST=127.0.0.1
BABYBOT_PORT=8787
BABYBOT_DATA_DIR=.babybot

# Use the TypeScript entry while developing kimi-code. Use dist/index.mjs for
# a built SDK. Relative paths are resolved from this repository.
KIMI_CODE_SDK_PATH=../Dev/kimi-code/packages/node-sdk/src/index.ts
# Uncomment to use an isolated kimi-code login and configuration directory.
# KIMI_CODE_HOME=.babybot/kimi-code
# Optional deployment override. Keep this commented when the model should be
# selected through Babybot's setup screen.
# KIMI_CODE_MODEL=provider/model
KIMI_CODE_PERMISSION=auto
KIMI_LOG_LEVEL=debug
