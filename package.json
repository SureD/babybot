{
  "name": "babybot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bash start.sh",
    "dev": "pnpm --parallel --filter @babybot/server --filter @babybot/web dev",
    "dev:server": "pnpm --filter @babybot/server dev",
    "dev:web": "pnpm --filter @babybot/web dev",
    "debug:server": "pnpm --filter @babybot/server debug",
    "debug:task": "node scripts/debug-task.mjs",
    "build": "pnpm --filter @babybot/server build && pnpm --filter @babybot/web build",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --type-aware --deny-warnings .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "kimi:install": "node scripts/kimi-code.mjs install",
    "kimi:build": "node scripts/kimi-code.mjs build",
    "kimi:typecheck": "node scripts/kimi-code.mjs typecheck",
    "kimi:test": "node scripts/kimi-code.mjs test"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "oxlint": "1.69.0",
    "oxlint-tsgolint": "0.23.0",
    "tsdown": "0.22.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "packageManager": "pnpm@10.33.0"
}
